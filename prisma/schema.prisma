generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id        String          @id @default(cuid())
  name      String
  domain    String?         @unique
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  companies Company[]
  deals     Deal[]
  sequences EmailSequence[]
  events    Event[]
  people    Person[]
  users     User[]
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  firstName String?
  lastName  String?
  role      UserRole @default(USER)
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([clerkId])
  @@index([tenantId])
  @@index([email])
}

model Company {
  id                  String               @id @default(cuid())
  tenantId            String
  name                String
  website             String?
  industry            String?
  size                String?
  geography           String?
  status              String               @default("Lead")
  description         String?
  foundedYear         Int?
  sourceType          String?
  sourceQuery         String?
  confidence          Float?
  lifecycleStage      String               @default("lead")
  leadSource          String?
  leadScore           Int?
  lastEngaged         DateTime?
  emailOpens          Int                  @default(0)
  emailClicks         Int                  @default(0)
  websiteVisits       Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  websetId            String?
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  webset              Webset?              @relation(fields: [websetId], references: [id])
  deals               Deal[]
  events              Event[]
  people              Person[]
  sequenceEnrollments SequenceEnrollment[]

  @@index([tenantId])
  @@index([status])
  @@index([sourceType])
  @@index([website])
  @@index([websetId])
}

model Person {
  id           String   @id @default(cuid())
  tenantId     String
  firstName    String
  lastName     String
  email        String?
  phone        String?
  title        String?
  linkedin     String?
  companyId    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  websetId     String?
  primaryDeals Deal[]   @relation("PrimaryContact")
  events       Event[]
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  webset       Webset?  @relation(fields: [websetId], references: [id])

  @@index([tenantId])
  @@index([companyId])
  @@index([email])
  @@index([websetId])
}

model Deal {
  id               String    @id @default(cuid())
  tenantId         String
  title            String
  value            Float?
  stage            String    @default("Prospecting")
  probability      Int?
  closeDate        DateTime?
  description      String?
  nextAction       String?
  lostReason       String?
  stageChangedAt   DateTime?
  companyId        String
  primaryContactId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  primaryContact   Person?   @relation("PrimaryContact", fields: [primaryContactId], references: [id])
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  events           Event[]

  @@index([tenantId])
  @@index([companyId])
  @@index([stage])
  @@index([stageChangedAt])
}

model Event {
  id          String    @id @default(cuid())
  tenantId    String
  type        String
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  source      String    @default("manual")
  priority    String?
  outcome     String?
  emailStatus String?
  sequenceId  String?
  companyId   String?
  personId    String?
  dealId      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deal        Deal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  person      Person?   @relation(fields: [personId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([companyId])
  @@index([personId])
  @@index([dealId])
  @@index([type])
  @@index([source])
  @@index([dueDate])
  @@index([completed])
}

model EmailSequence {
  id                  String               @id @default(cuid())
  tenantId            String
  name                String
  description         String?
  active              Boolean              @default(true)
  pauseOnDealCreation Boolean              @default(true)
  pauseOnDealStages   String[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  steps               EmailSequenceStep[]
  enrollments         SequenceEnrollment[]

  @@index([tenantId])
}

model EmailSequenceStep {
  id         String        @id @default(cuid())
  sequenceId String
  stepOrder  Int
  delayDays  Int
  subject    String
  body       String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  sequence   EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, stepOrder])
  @@index([sequenceId])
}

model SequenceEnrollment {
  id              String           @id @default(cuid())
  sequenceId      String
  companyId       String
  status          String           @default("active")
  pauseReason     String?
  currentStep     Int              @default(0)
  enrolledAt      DateTime         @default(now())
  completedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  scheduledEmails ScheduledEmail[]
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sequence        EmailSequence    @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
  @@index([companyId])
  @@index([status])
}

model ScheduledEmail {
  id            String             @id @default(cuid())
  enrollmentId  String
  stepOrder     Int
  subject       String
  body          String
  scheduledFor  DateTime
  status        String             @default("scheduled")
  sentAt        DateTime?
  emailProvider String?
  externalId    String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  enrollment    SequenceEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@index([status])
  @@index([scheduledFor])
}

model Webset {
  id          String    @id @default(cuid())
  tenantId    String
  exaId       String    @unique
  type        String
  status      String
  query       String
  criteria    Json
  resultCount Int       @default(0)
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  companies   Company[]
  people      Person[]

  @@index([tenantId])
  @@index([status])
  @@index([type])
  @@index([createdBy])
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  USER
  READONLY
}
